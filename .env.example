ENABLE_REAL_LLM=false
# DeepSeek 当前模型/账户未启用 Strict Function Calling 时保持 false，直接使用 json_object。
DEEPSEEK_STRICT_TOOL_ENABLED=false
# 服务端模型密钥。只写入本机 .env，绝不能使用 VITE_ 前缀。
LLM_API_KEY=
# OpenAI-compatible API 根地址，例如 https://api.openai.com/v1
LLM_BASE_URL=
# 服务端固定模型名，浏览器不能覆盖。
LLM_MODEL=
# 单次上游请求超时（毫秒）。
LLM_REQUEST_TIMEOUT_MS=8000
# 单个客户端每分钟最多调用次数。
LLM_MAX_REQUESTS_PER_MINUTE=10
# Demo 每日保守估算 Token 预算。
LLM_DAILY_TOKEN_BUDGET=50000
# 逗号分隔的允许前端 Origin。
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# 服务端监听地址。容器内通常使用 0.0.0.0，本地开发可使用 127.0.0.1。
HOST=127.0.0.1
PORT=8787
