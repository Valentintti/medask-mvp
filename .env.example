# 服务端模型密钥。只写入本机 .env，绝不能使用 VITE_ 前缀。
LLM_API_KEY=
# OpenAI-compatible API 根地址，例如 https://api.openai.com/v1
LLM_BASE_URL=
# 服务端固定模型名，浏览器不能覆盖。
LLM_MODEL=
# 单次上游请求超时（毫秒）。
LLM_REQUEST_TIMEOUT_MS=8000
# 单个客户端每分钟最多调用次数。
LLM_MAX_REQUESTS_PER_MINUTE=10
# Demo 每日保守估算 Token 预算。
LLM_DAILY_TOKEN_BUDGET=50000
# 只有精确为 true 才启用真实模型。
ENABLE_REAL_LLM=false
# 逗号分隔的额外前端 Origin；本地 127.0.0.1:5173 与 localhost:5173 默认允许。
LLM_ALLOWED_ORIGINS=
# 服务端监听地址与端口。
LLM_SERVER_HOST=127.0.0.1
LLM_SERVER_PORT=8787
