{
  "name": "medask-mvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx watch server/index.ts",
    "start": "node dist-server/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "build:client": "vite build && node scripts/check-client-bundle-secrets.mjs",
    "build:server": "vite build --config vite.server.config.ts",
    "build": "pnpm typecheck && pnpm build:client && pnpm build:server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:usability": "playwright test tests/usability-simulation.spec.ts",
    "eval:real": "tsx scripts/evaluate-real-provider.ts",
    "eval:v2:real": "tsx scripts/evaluate-v2-real-provider.ts",
    "eval:v2": "tsx scripts/evaluate-v2-complaints.ts",
    "prepare:abdominal-review": "node scripts/prepare-abdominal-pain-review.mjs",
    "eval:abdominal-review": "node scripts/evaluate-abdominal-pain-review.mjs",
    "prepare:abdominal-adjudication": "node scripts/prepare-abdominal-pain-adjudication.mjs",
    "eval:abdominal-adjudication": "node scripts/evaluate-abdominal-pain-adjudication.mjs"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
